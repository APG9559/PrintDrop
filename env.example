# ─────────────────────────────────────────────────────────────────────────────
# PrintDrop — environment variables
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=development

# CORS — restrict to your domain in production
# ALLOWED_ORIGIN=https://printdrop.yourshop.in

# ── Box Platform (JWT App) ────────────────────────────────────────────────────
# Obtain from https://developer.box.com → your app → Configuration
BOX_CLIENT_ID=
BOX_CLIENT_SECRET=
BOX_ENTERPRISE_ID=

# JWT key pair
BOX_KEY_ID=
# Paste the full PEM block on a single line with literal \n between lines:
# -----BEGIN ENCRYPTED PRIVATE KEY-----\nMIIF...\n-----END ENCRYPTED PRIVATE KEY-----
BOX_PRIVATE_KEY=
BOX_PASSPHRASE=

# The Box folder ID where daily upload folders will be created
# (visible in the Box web URL: app.box.com/folder/<ID>)
BOX_UPLOAD_FOLDER_ID=
